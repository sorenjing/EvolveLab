# 复制本文件为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会上传）
# 以智谱 AI 为例，可在 https://open.bigmodel.cn/ 申请 API Key

# ---------- LLM 配置 ----------
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4-flash

# ---------- Agent 行为 ----------
# Agent 最大推理步数
MAX_STEPS=15

# ---------- 安全与持久化（可选）----------
# Agent 流接口鉴权 token（为空则不鉴权，仅本地开发用；公网部署务必设置）
AGENT_TOKEN=
# 会话持久化 Redis URL（为空则用内存 dict，重启即丢；生产建议设置）
REDIS_URL=

# ---------- 服务监听（可选）----------
# 默认仅监听 localhost；需外网访问设为 0.0.0.0
HOST=127.0.0.1
PORT=8001
# CORS 允许的前端地址（逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
